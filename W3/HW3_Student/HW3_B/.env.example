# Copy this file to .env and fill in your real values from the 7-column handout CSV.
# DO NOT COMMIT .env to git.
#
# You should have received from the instructor:
#   1. A row of `hw03_credentials_handout.csv` (your 7 values)
#   2. SHARED.txt (the same for all 47 students)
#
# Workflow:
#   cp .env.example .env
#   # Edit the PER-STUDENT section below with your 7 values from the handout
#   # Copy the SHARED section verbatim from SHARED.txt
#   source .env

# ============================================================================
# PER-STUDENT (paste from your row of hw03_credentials_handout.csv)
# ============================================================================

# === Student identity (col 1-2) ===
STUDENT_USERNAME=student_your_username_here

# === MLflow (col 3-4) — same as HW2, just a new experiment name ===
MLFLOW_TRACKING_USERNAME=student_your_username_here
MLFLOW_TRACKING_PASSWORD=paste_from_handout_csv

# === MinIO (col 5-6) ===
MINIO_ACCESS_KEY=qbc12-your_username_here
MINIO_SECRET_KEY=paste_from_handout_csv

# === Postgres (col 7) — pre-issued for HW3_C, not used by HW3_B ===
PG_PASSWORD=paste_from_handout_csv

# ============================================================================
# SHARED (paste from SHARED.txt — same for all 47 students)
# ============================================================================

MLFLOW_TRACKING_URI=http://185.50.38.163:33014
MLFLOW_EXPERIMENT_NAME=qbc12_hw03_encoder_your_username_here
MODEL_NAME=qbc12_hw03_encoder_your_username_here

QDRANT_URL=http://185.50.38.163:6333
QDRANT_API_KEY=paste_from_shared_txt
QDRANT_COLLECTION=qbc12_corpus

MINIO_ENDPOINT=185.50.38.163:33333
MINIO_BUCKET=hw03-bundles
MINIO_PREFIX=your_username_here/

DATABASE_HOST=185.50.38.163
DATABASE_PORT=32112
DATABASE_NAME=qbc12_hw03_encoder
DATABASE_API_RO_PASSWORD=paste_from_shared_txt
DATABASE_URL=postgresql://qbc12_hw03_api_ro:${DATABASE_API_RO_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}

MODEL_REGISTRY_URL=http://185.50.38.163:33200/

# === Bundle artifact contract (matches instructor's reference bundle) ===
EMBEDDING_MODEL_ID=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIM=384
EMBEDDING_MAX_SEQ_LEN=256

# ============================================================================
# Local dev defaults (override in container via env_file in compose.yaml)
# ============================================================================

BUNDLE_DIR=../HW3_A/bundle
BUNDLE_DEVICE=cpu
MODEL_SOURCE=baked  # baked | local | s3

# Container-only — entrypoint.sh sets these; for local dev set manually:
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2
TOKENIZERS_PARALLELISM=false
PORT=8000
UVICORN_WORKERS=1
LOG_LEVEL=info
