# HW3_C student-specific environment
# Copy this to .env and fill in your values from hw03_c_handout.zip

# === From your hw03_c_handout.zip ===
USERNAME=                  # e.g., nazanin_hesari (make sure to change the underscore to "-" instead of the initial "_")
NODEPORT=                  # e.g., 30090 (from node-port.txt)
KUBECONFIG_PATH=./kubeconfig.yaml

# === Shared server endpoints (same for everyone) ===
REGISTRY=185.50.38.163:35000
SERVER_HOST=185.50.38.163
K3S_API=https://185.50.38.163:6443

# === Your service URL (after you deploy) ===
SERVICE_URL=http://${SERVER_HOST}:${NODEPORT}

# === Your namespace (DO NOT change) ===
NAMESPACE=qbc12-hw03-c-${USERNAME}
